<Window x:Class="AgentDock.Windows.ScheduleMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Message"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="/Assets/agentdock.png"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource HelpForeground}" />
            <Setter Property="Background" Value="{DynamicResource HelpCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HelpCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MenuHighlightBackground}" />
                            </Trigger>
                            <Trigger Property="IsDefault" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource TabButtonActiveBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumberBox" TargetType="{x:Type TextBox}">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MaxLength" Value="4" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource HelpForeground}" />
            <Setter Property="Background" Value="{DynamicResource HelpCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HelpCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource HelpBackground}"
            BorderBrush="{DynamicResource ToolbarBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title bar -->
                <RowDefinition Height="Auto" /> <!-- Message preview -->
                <RowDefinition Height="Auto" /> <!-- Compose / Manage -->
                <RowDefinition Height="Auto" /> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Mini title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackground}"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="Schedule Message"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,8"
                               Foreground="{DynamicResource TitleBarForeground}" />
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="42"
                            Cursor="Hand"
                            ToolTip="Close"
                            Foreground="{DynamicResource TitleBarForeground}"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="0,4,0,0">
                                    <TextBlock x:Name="Glyph"
                                               Text="&#xE8BB;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123" />
                                        <Setter TargetName="Glyph" Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Message preview -->
            <StackPanel Grid.Row="1" Margin="16,14,16,4">
                <TextBlock Text="Message"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,6" />
                <Border Background="{DynamicResource HelpCardBackground}"
                        BorderBrush="{DynamicResource HelpCardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="MessagePreview"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource HelpForeground}"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 Padding="8,6" />
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Compose: how long to wait -->
            <StackPanel x:Name="ComposeSection" Grid.Row="2" Margin="16,14,16,4">
                <TextBlock Text="Send after"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="HoursBox"
                             Style="{StaticResource NumberBox}"
                             PreviewTextInput="Digits_PreviewTextInput"
                             TextChanged="Duration_TextChanged" />
                    <TextBlock Text="hours"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="6,0,16,0"
                               Foreground="{DynamicResource HelpForeground}" />
                    <TextBox x:Name="MinutesBox"
                             Style="{StaticResource NumberBox}"
                             PreviewTextInput="Digits_PreviewTextInput"
                             TextChanged="Duration_TextChanged" />
                    <TextBlock Text="minutes"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               Foreground="{DynamicResource HelpForeground}" />
                </StackPanel>
                <TextBlock x:Name="ComposeHint"
                           FontSize="11"
                           Foreground="{DynamicResource HelpForeground}"
                           Opacity="0.7"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Manage: time remaining for an already-scheduled message -->
            <StackPanel x:Name="ManageSection" Grid.Row="2" Margin="16,14,16,4" Visibility="Collapsed">
                <TextBlock Text="Sends in"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="RemainingText"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           Foreground="{DynamicResource HelpForeground}" />
                <TextBlock x:Name="FireAtText"
                           FontSize="11"
                           Foreground="{DynamicResource HelpForeground}"
                           Opacity="0.7"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="3" Margin="16,18,16,16">
                <!-- Compose buttons -->
                <StackPanel x:Name="ComposeButtons"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Schedule"
                            Style="{StaticResource DialogButton}"
                            IsDefault="True"
                            Click="ScheduleButton_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Cancel"
                            Style="{StaticResource DialogButton}"
                            IsCancel="True"
                            Click="CloseButton_Click" />
                </StackPanel>
                <!-- Manage buttons -->
                <StackPanel x:Name="ManageButtons"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button Content="Cancel Schedule"
                            Style="{StaticResource DialogButton}"
                            Foreground="{DynamicResource ChatDangerForeground}"
                            Click="CancelScheduleButton_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Keep"
                            Style="{StaticResource DialogButton}"
                            IsDefault="True"
                            IsCancel="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
