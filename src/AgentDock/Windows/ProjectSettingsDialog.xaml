<Window x:Class="AgentDock.Windows.ProjectSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Settings"
        Width="420" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="/Assets/agentdock.png"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource HelpForeground}" />
            <Setter Property="Background" Value="{DynamicResource HelpCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HelpCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MenuHighlightBackground}" />
                            </Trigger>
                            <Trigger Property="IsDefault" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource TabButtonActiveBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource HelpBackground}"
            BorderBrush="{DynamicResource ToolbarBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title bar -->
                <RowDefinition Height="Auto" /> <!-- Project Name -->
                <RowDefinition Height="Auto" /> <!-- Icon preview row -->
                <RowDefinition Height="Auto" /> <!-- Icon grid (collapsible) -->
                <RowDefinition Height="Auto" /> <!-- Icon Colour -->
                <RowDefinition Height="Auto" /> <!-- Sounds header -->
                <RowDefinition Height="Auto" /> <!-- Sounds section (collapsible) -->
                <RowDefinition Height="Auto" /> <!-- Description -->
                <RowDefinition Height="Auto" /> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Mini title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackground}"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Project Settings"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,8"
                               Foreground="{DynamicResource TitleBarForeground}" />
                    <!-- Always-visible close (acts as Cancel), reachable even with the icon grid open -->
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="42"
                            Cursor="Hand"
                            ToolTip="Close (Cancel)"
                            Foreground="{DynamicResource TitleBarForeground}"
                            Click="CancelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="0,4,0,0">
                                    <TextBlock x:Name="Glyph"
                                               Text="&#xE8BB;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123" />
                                        <Setter TargetName="Glyph" Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Project Name -->
            <StackPanel Grid.Row="1" Margin="16,14,16,4">
                <TextBlock Text="Project Name"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="NameTextBox"
                         FontSize="13"
                         MaxLength="120"
                         Height="28"
                         VerticalContentAlignment="Center"
                         Foreground="{DynamicResource HelpForeground}"
                         Background="{DynamicResource HelpCardBackground}"
                         BorderBrush="{DynamicResource HelpCardBorderBrush}"
                         BorderThickness="1"
                         Padding="6,0" />
                <TextBlock x:Name="NameHintText"
                           FontSize="10"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource HelpForeground}" />
            </StackPanel>

            <!-- Icon preview row -->
            <StackPanel Grid.Row="2" Margin="16,14,16,4">
                <TextBlock Text="Icon"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Change..."
                            Style="{StaticResource DialogButton}"
                            Click="ChangeIcon_Click"
                            VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="IconPreviewBorder"
                                Width="40" Height="40"
                                CornerRadius="4"
                                BorderBrush="{DynamicResource HelpCardBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Viewbox x:Name="IconPreviewHost"
                                     Width="24" Height="24"
                                     Stretch="Uniform" />
                        </Border>
                        <TextBlock x:Name="IconPreviewLabel"
                                   Text="Folder"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource HelpForeground}" />
                    </StackPanel>
                </DockPanel>
            </StackPanel>

            <!-- Icon grid (collapsed by default) -->
            <StackPanel x:Name="IconGridSection" Grid.Row="3" Margin="16,8,16,4"
                        Visibility="Collapsed">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="IconSearchBox"
                             Grid.Column="0"
                             FontSize="12"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Foreground="{DynamicResource HelpForeground}"
                             Background="{DynamicResource HelpCardBackground}"
                             BorderBrush="{DynamicResource HelpCardBorderBrush}"
                             BorderThickness="1"
                             Padding="6,0"
                             TextChanged="IconSearch_TextChanged" />
                    <TextBlock x:Name="IconSearchWatermark"
                               Grid.Column="0"
                               Text="Search icons…"
                               FontSize="12"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Opacity="0.5"
                               Foreground="{DynamicResource HelpForeground}" />
                    <Button x:Name="IconPickerCancelButton"
                            Grid.Column="1"
                            Content="Cancel"
                            Style="{StaticResource DialogButton}"
                            Height="26"
                            MinWidth="64"
                            Margin="6,0,0,0"
                            ToolTip="Close icon picker"
                            Click="CancelIconPicker_Click" />
                </Grid>
                <ScrollViewer MaxHeight="200"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="BuiltInHeader"
                                   Text="Built-in"
                                   FontSize="11"
                                   Foreground="{DynamicResource HelpForeground}"
                                   Margin="0,0,0,4" />
                        <WrapPanel x:Name="BuiltInPanel" />
                        <TextBlock x:Name="NoIconsLabel"
                                   Text="No matching icons"
                                   FontSize="11"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource HelpForeground}"
                                   Margin="2,4,0,4" />
                        <StackPanel x:Name="DiscoveredSection" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="Discovered"
                                       FontSize="11"
                                       Foreground="{DynamicResource HelpForeground}"
                                       Margin="0,0,0,4" />
                            <WrapPanel x:Name="DiscoveredPanel" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <!-- Icon Colour swatches -->
            <StackPanel Grid.Row="4" Margin="16,12,16,4">
                <TextBlock Text="Icon Colour"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <WrapPanel x:Name="ForegroundSwatchPanel" />
            </StackPanel>

            <!-- Sounds header -->
            <StackPanel Grid.Row="5" Margin="16,12,16,4">
                <TextBlock Text="Sounds"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Configure..."
                            Style="{StaticResource DialogButton}"
                            Click="ConfigureSounds_Click"
                            VerticalAlignment="Center" />
                    <TextBlock x:Name="SoundsSummaryLabel"
                               Text="All enabled"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource HelpForeground}" />
                </DockPanel>
            </StackPanel>

            <!-- Sounds section (collapsed by default) -->
            <StackPanel x:Name="SoundsSection" Grid.Row="6" Margin="16,8,16,4"
                        Visibility="Collapsed">
                <CheckBox x:Name="SoundOnStartCheckBox"
                          Content="Session start"
                          FontSize="12"
                          Foreground="{DynamicResource HelpForeground}"
                          Margin="0,4,0,4" />
                <CheckBox x:Name="SoundOnWaitingCheckBox"
                          Content="Agent waiting for input"
                          FontSize="12"
                          Foreground="{DynamicResource HelpForeground}"
                          Margin="0,4,0,4" />
                <CheckBox x:Name="SoundOnEndCheckBox"
                          Content="Session end"
                          FontSize="12"
                          Foreground="{DynamicResource HelpForeground}"
                          Margin="0,4,0,4" />
            </StackPanel>

            <!-- Project Description -->
            <StackPanel Grid.Row="7" Margin="16,12,16,4">
                <TextBlock Text="Project Description"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HelpForeground}"
                           Margin="0,0,0,8" />
                <TextBox x:Name="DescriptionTextBox"
                         FontSize="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MaxLength="500"
                         Height="60"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{DynamicResource HelpForeground}"
                         Background="{DynamicResource HelpCardBackground}"
                         BorderBrush="{DynamicResource HelpCardBorderBrush}"
                         BorderThickness="1"
                         Padding="6,4" />
            </StackPanel>

            <!-- OK / Cancel buttons -->
            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16,14,16,16">
                <Button Content="OK"
                        Style="{StaticResource DialogButton}"
                        IsDefault="True"
                        Click="OkButton_Click"
                        Margin="0,0,8,0" />
                <Button Content="Cancel"
                        Style="{StaticResource DialogButton}"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
